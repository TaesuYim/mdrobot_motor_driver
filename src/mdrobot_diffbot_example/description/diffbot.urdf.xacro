<?xml version="1.0"?>
<!-- Minimal 2-wheel differential-drive robot driven by a MDROBOT dual controller
     (PNT50 / MD400T) through mdrobot_ros2_control. Geometry here is an EXAMPLE —
     measure wheel_radius / wheel_separation for your robot and keep them in sync
     with config/diffbot_controllers.yaml. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mdrobot_diffbot">

  <xacro:arg name="use_mock_hardware" default="true"/>
  <xacro:arg name="port" default="/dev/ttyUSB0"/>
  <xacro:arg name="baudrate" default="19200"/>
  <xacro:arg name="motor_id" default="1"/>
  <!-- PNT50 measured: 12 counts/rev (hall, 3 x 4-pole). Measure for your motor. -->
  <xacro:arg name="counts_per_rev" default="12.0"/>

  <!-- geometry (must match diff_drive_controller wheel_radius / wheel_separation) -->
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_separation" value="0.30"/>
  <xacro:property name="base_len" value="0.30"/>
  <xacro:property name="base_wid" value="0.22"/>
  <xacro:property name="base_hei" value="0.10"/>
  <xacro:property name="caster_radius" value="0.025"/>

  <material name="blue"><color rgba="0.2 0.3 0.8 1.0"/></material>
  <material name="dark"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <xacro:macro name="box_inertial" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" iyy="${m*(x*x+z*z)/12}" izz="${m*(x*x+y*y)/12}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>
  <xacro:macro name="cyl_inertial" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+l*l)/12}" iyy="${m*(3*r*r+l*l)/12}" izz="${m*r*r/2}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ground projection -->
  <link name="base_footprint"/>

  <!-- body, origin at wheel-axle height -->
  <link name="base_link">
    <visual>
      <geometry><box size="${base_len} ${base_wid} ${base_hei}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="${base_len} ${base_wid} ${base_hei}"/></geometry>
    </collision>
    <xacro:box_inertial m="5.0" x="${base_len}" y="${base_wid}" z="${base_hei}"/>
  </link>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- wheels: continuous, axle along y, roll about y -->
  <xacro:macro name="wheel" params="name y">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cyl_inertial m="0.5" r="${wheel_radius}" l="${wheel_width}"/>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="0 ${y} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>
  <xacro:wheel name="left_wheel" y="${wheel_separation/2}"/>
  <xacro:wheel name="right_wheel" y="${-wheel_separation/2}"/>

  <!-- front caster (sphere) for support -->
  <link name="caster">
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="grey"/>
    </visual>
    <collision><geometry><sphere radius="${caster_radius}"/></geometry></collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="${base_len/2 - caster_radius} 0 ${caster_radius - wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ros2_control -->
  <xacro:include filename="$(find mdrobot_diffbot_example)/description/diffbot.ros2_control.xacro"/>
  <xacro:diffbot_ros2_control
      name="mdrobot_diffbot"
      use_mock_hardware="$(arg use_mock_hardware)"
      port="$(arg port)"
      baudrate="$(arg baudrate)"
      motor_id="$(arg motor_id)"
      counts_per_rev="$(arg counts_per_rev)"/>
</robot>
